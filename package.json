{
  "name": "vts-deck",
  "productName": "VTS Deck",
  "author": "greysdawn",
  "description": "VTS Deck",
  "version": "1.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "build:win64": "deno compile -A --no-check --target x86_64-pc-windows-msvc -o ./dist/vtsdeck_win_x86_64 ./index.js",
    "build:linux64": "deno compile -A --no-check --target x86_64-unknown-linux-gnu -o ./dist/vtsdeck_linux_x86_64 ./index.js",
    "build:linuxarm": "deno compile -A --no-check --target aarch64-unknown-linux-gnu -o ./dist/vtsdeck_linux_arm ./index.js",
    "build:mac64": "deno compile -A --no-check --target x86_64-apple-darwin -o ./dist/vtsdeck_mac_x86_64 ./index.js",
    "build:macarm": "deno compile -A --no-check --target aarch64-apple-darwin -o ./dist/vtsdeck_mac_arm ./index.js",
    "build:all": "deno task build:win64 && deno task build:linux64 && deno task build:linuxarm && deno task build:mac64 && deno task build:macarm"
  },
  "compile": {
    "include": [ "build" ]
  },
  "devDependencies": {
    "@iconify/json": "^2.2.491",
    "@iconify/tailwind": "^1.2.0",
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "autoprefixer": "^10.5.2",
    "axios": "^1.18.1",
    "flowbite": "^2.5.2",
    "flowbite-svelte": "^0.46.23",
    "postcss": "^8.5.15",
    "svelte": "^5.56.4",
    "svelte-awesome-color-picker": "^3.1.4",
    "tailwindcss": "^3.4.19",
    "unplugin-icons": "^0.19.3",
    "vite": "^5.4.21",
    "ws": "^8.21.0"
  },
  "type": "module",
  "dependencies": {
    "@shopify/draggable": "^1.2.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "nanoid": "^5.1.16",
    "open": "^11.0.0",
    "svelte-adapter-bun": "^1.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
